{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["ANDROID_HOME", "ANDROID_SDK_ROOT"],
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "dependsOn": ["^build"],
      "env": [
        "CLERK_SECRET_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_CONVEX_URL",
        "NEXT_PUBLIC_MAPBOX_TOKEN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:ios": {
      "cache": false,
      "persistent": true
    },
    "dev:android": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "lint": {},
    "typecheck": {},
    "format": {},
    "format:check": {},
    "clean": {
      "cache": false
    },
    "codegen": {
      "cache": false
    },
    "deploy": {
      "cache": false
    },
    "prebuild": {
      "cache": false
    },
    "prebuild:clean": {
      "cache": false
    }
  },
  "ui": "tui"
}
