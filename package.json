{
  "name": "fomo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean && rm -rf node_modules",
    "convex:codegen": "turbo run codegen --filter=@fomo/backend",
    "convex:deploy": "turbo run deploy --filter=@fomo/backend",
    "convex:dev": "turbo run dev --filter=@fomo/backend",
    "dev": "turbo dev",
    "dev:android": "turbo dev:android --filter=@fomo/mobile --filter=@fomo/backend",
    "dev:backend": "turbo dev --filter=@fomo/backend",
    "dev:ios": "turbo dev:ios --filter=@fomo/mobile --filter=@fomo/backend",
    "dev:mobile": "turbo dev --filter=@fomo/mobile --filter=@fomo/backend",
    "dev:web": "turbo dev --filter=@fomo/web --filter=@fomo/backend",
    "format": "turbo format && prettier --write '*.{cjs,json}' --ignore-unknown --no-error-on-unmatched-pattern",
    "format:check": "turbo format:check && prettier --check '*.{cjs,json}' --ignore-unknown --no-error-on-unmatched-pattern",
    "lint": "turbo lint",
    "mobile:prebuild": "turbo run prebuild --filter=@fomo/mobile",
    "mobile:prebuild:clean": "turbo run prebuild:clean --filter=@fomo/mobile",
    "prepare": "husky",
    "typecheck": "turbo typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@t3-oss/env-core": "^0.13.10",
    "@t3-oss/env-nextjs": "^0.13.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.5",
    "typescript": "^5",
    "zod": "^3.24.1"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "reactDoctor": {
    "diff": "main"
  }
}
