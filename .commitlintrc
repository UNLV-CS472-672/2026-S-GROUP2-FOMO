{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "backend",
        "mobile",
        "web",
        "deps",
        "config",
        "api",
        "data-ml",
        "theme",
        "env"
      ]
    ],
    "subject-case": [0, "never", ["sentence-case"]]
  }
}

