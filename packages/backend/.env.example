# Convex backend environment variable reference.
# Set these in Convex deployment environment variables, either:
# - Convex dashboard UI, or
# - CLI: `pnpm exec convex env set <NAME> <VALUE>`
# This file is a template/reference and does NOT populate deployment env vars.

# JWT issuer domain from Clerk Dashboard → JWT Templates (e.g. https://your-app.clerk.accounts.dev)
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# Clerk webhook signing secret from Clerk Dashboard → Webhooks (starts with whsec_)
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ticketmaster API key (required only for eventsIngest:syncTicketmasterLasVegas)
TICKETMASTER_API_KEY=your_ticketmaster_api_key
