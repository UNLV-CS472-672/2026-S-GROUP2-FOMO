# Mobile app (Expo)
# Copy to .env.local and fill in values.

# Convex deployment URL (Android emulator: http://10.0.2.2:3210, iOS sim: http://127.0.0.1:3210)
EXPO_PUBLIC_CONVEX_URL=http://10.0.2.2:3210

# Clerk (https://dashboard.clerk.com → API Keys)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Mapbox (https://account.mapbox.com → Access tokens)
EXPO_PUBLIC_MAPBOX_TOKEN=pk.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXX
